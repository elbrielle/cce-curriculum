<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Exit Ticket {{ page_id }} — {{ subtitle }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="exit-tickets.css">
<link rel="stylesheet" href="exit-tickets-round2.css">
<style>
  /* Fallback-body styles for the six formats whose designed components are still TODO. */
  .eb__fallback {
    font-size: 10.5pt;
    line-height: 1.5;
    color: var(--ink);
  }
  .eb__fallback p { margin: 0 0 8pt 0; }
  .eb__fallback ul, .eb__fallback ol { margin: 0 0 8pt 0; padding-left: 20pt; }
  .eb__fallback li { margin-bottom: 4pt; }
  .eb__fallback strong { font-weight: 700; }
  .eb__fallback em { font-style: italic; }
  .eb__fallback table {
    width: 100%;
    border-collapse: collapse;
    margin: 4pt 0 10pt 0;
    font-size: 10pt;
  }
  .eb__fallback table th, .eb__fallback table td {
    border: 0.6pt solid var(--ink);
    padding: 6pt 8pt;
    vertical-align: top;
    text-align: left;
  }
  .eb__fallback table thead th {
    background: var(--navy);
    color: var(--paper);
    font-family: var(--serif);
    font-weight: 700;
    font-size: 9.5pt;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  /* Underscore-only paragraph -> full-width gold-tinted writing slot.
     Matches the design system's answer-region treatment. */
  .eb__fallback .fb-line {
    background-color: var(--gold-tint);
    border: 0.6pt solid #c9a826;
    height: 9mm;
    margin: 6pt 0 10pt 0;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  /* Inline underscore run -> gold-tinted fill-in box. ~2in min-width gives
     room for a phrase; a single inline blank can grow if it has more space. */
  .eb__fallback .fb-blank {
    display: inline-block;
    background-color: var(--gold-tint);
    border: 0.6pt solid #c9a826;
    min-width: 2in;
    height: 1.4em;
    vertical-align: bottom;
    margin: 0 1pt;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  /* Print-color-adjust on every tinted region. */
  @media print {
    .eb__fallback table thead th { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .eb__fallback .fb-line, .eb__fallback .fb-blank { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
</head>
<body>

<section class="sheet{% if half_page %} sheet--half{% endif %}">

  <header class="eh">
    <div class="eh__title-block">
      <h1 class="eh__title">EXIT TICKET</h1>
      <div class="eh__subtitle">{{ subtitle }}</div>
    </div>
    <div class="eh__mark">
      <img src="assets/iisd-logo.png" alt="Irving ISD">
      <div class="eh__mark-sub">Career &amp;<br>College Explorations</div>
    </div>
    <div class="eh__meta">
      <div class="eh__meta-block is-block">
        <div class="eh__meta-label">Block</div>
        <div class="eh__meta-value">{{ block_tile }}</div>
      </div>
      <div class="eh__meta-block has-fill">
        <div class="eh__meta-label">Name</div>
        <div class="eh__meta-value eh__meta-value--fill">&nbsp;</div>
      </div>
      <div class="eh__meta-block has-fill">
        <div class="eh__meta-label">Date</div>
        <div class="eh__meta-value eh__meta-value--fill">&nbsp;</div>
      </div>
      <div class="eh__meta-block has-fill is-period">
        <div class="eh__meta-label">Period</div>
        <div class="eh__meta-value eh__meta-value--fill">&nbsp;</div>
      </div>
      {% if teks_chip %}
      <div class="eh__meta-block has-teks">
        <div class="teks">{{ teks_chip }}</div>
      </div>
      {% endif %}
    </div>
  </header>

  <div class="eb">
    <div class="eb__head">
      <div class="eb__glyph" title="{{ format_name }}">
        {{ glyph_svg | safe }}
      </div>
      <div class="eb__format">{{ format_name }}</div>
      <div class="eb__format-num">{{ format_num }}</div>
    </div>

    {# ====================================================================
       BODY: structured for the four designed formats, fallback for the rest.
       ===================================================================== #}

    {% if format_id == "mcq" and mcq.options %}
      {% if mcq.scenario %}<p class="scenario">{{ mcq.scenario }}</p>{% endif %}
      {% if mcq.stem %}<p class="stem"><strong>{{ mcq.stem }}</strong></p>{% endif %}
      <ol class="mcq__list">
        {% for opt in mcq.options %}
        <li class="mcq__opt"><span class="mcq__letter">{{ opt.letter }}</span><span>{{ opt.text }}</span></li>
        {% endfor %}
      </ol>
      {% if mcq.callout %}<div class="callout">{{ mcq.callout }}</div>{% endif %}
      <div class="lines lines--n5"></div>

    {% elif format_id == "matrix" and matrix.columns %}
      {% if matrix.stem %}<p class="stem"><strong>{{ matrix.stem }}</strong></p>{% endif %}
      <table class="matrix">
        <thead>
          <tr>
            <th style="width:1.4in">&nbsp;</th>
            {% for col in matrix.columns %}<th>{{ col }}</th>{% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in matrix.rows %}
          <tr>
            <th>{{ row.label }}{% if row.sublabel %}<br><span style="font-weight:400;color:var(--ink-mute);font-size:8.5pt">{{ row.sublabel }}</span>{% endif %}</th>
            {% for _ in matrix.columns %}<td></td>{% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% if matrix.callout %}<div class="callout">{{ matrix.callout }}</div>{% endif %}
      <div class="lines lines--n4"></div>

    {% elif format_id == "venn" and venn.left_label and venn.right_label %}
      {% if venn.stem %}<p class="stem"><strong>{{ venn.stem }}</strong></p>{% endif %}
      <div class="venn-wrap">
        <svg class="venn" viewBox="0 0 650 360" preserveAspectRatio="xMidYMid meet" aria-label="Venn diagram">
          <defs>
            <clipPath id="leftC"><circle cx="240" cy="180" r="160"/></clipPath>
            <clipPath id="rightC"><circle cx="410" cy="180" r="160"/></clipPath>
          </defs>
          <g clip-path="url(#leftC)"><circle cx="410" cy="180" r="160" fill="#fdf4d4"/></g>
          <circle cx="240" cy="180" r="160" fill="none" stroke="#15202b" stroke-width="1.2"/>
          <circle cx="410" cy="180" r="160" fill="none" stroke="#15202b" stroke-width="1.2"/>
          <text x="160" y="80" font-family="Space Grotesk" font-weight="700" font-size="13" fill="#004d7c" letter-spacing="1.4">{{ venn.left_label | upper }}</text>
          <text x="475" y="80" font-family="Space Grotesk" font-weight="700" font-size="13" fill="#004d7c" letter-spacing="1.4">{{ venn.right_label | upper }}</text>
          <text x="297" y="100" font-family="Space Grotesk" font-weight="700" font-size="10" fill="#76001a" letter-spacing="1.2">BOTH</text>
          <g stroke="#2a3540" stroke-width="0.5">
            <line x1="105" y1="150" x2="215" y2="150"/>
            <line x1="105" y1="180" x2="215" y2="180"/>
            <line x1="105" y1="210" x2="215" y2="210"/>
            <line x1="105" y1="240" x2="215" y2="240"/>
            <line x1="270" y1="150" x2="380" y2="150"/>
            <line x1="270" y1="180" x2="380" y2="180"/>
            <line x1="270" y1="210" x2="380" y2="210"/>
            <line x1="270" y1="240" x2="380" y2="240"/>
            <line x1="435" y1="150" x2="545" y2="150"/>
            <line x1="435" y1="180" x2="545" y2="180"/>
            <line x1="435" y1="210" x2="545" y2="210"/>
            <line x1="435" y1="240" x2="545" y2="240"/>
          </g>
        </svg>
        <div class="venn-legend">
          <div class="sw"><b>{{ venn.left_label }} only</b> — left side</div>
          <div class="sw"><b>Both</b> — overlap</div>
          <div class="sw"><b>{{ venn.right_label }} only</b> — right side</div>
        </div>
      </div>
      {% if venn.callout %}<div class="callout">{{ venn.callout }}</div>{% endif %}
      <div class="lines lines--n3"></div>

    {% elif format_id == "short_response" %}
      {% if short_response.stem %}<p class="stem">{{ short_response.stem | safe }}</p>{% endif %}
      <div class="lines lines--n9"></div>

    {% elif format_id == "concept_map" and concept_map.nodes %}
      <div class="cmap">
        {% if concept_map.center_prompt %}<p class="stem">{{ concept_map.center_prompt }}:</p>{% endif %}
        <div class="center-anchor">
          <span class="lbl">Center</span>
          {% if concept_map.center_value %}<span class="val" style="border-bottom:none; min-width:0; padding:0 4pt; color:var(--paper); font-family:var(--serif); font-weight:700">{{ concept_map.center_value }}</span>{% else %}<span class="val">&nbsp;</span>{% endif %}
        </div>
        {% if concept_map.intro %}<p class="stem" style="margin-top:2pt"><strong>{{ concept_map.intro }}</strong></p>{% endif %}
        <div class="cmap__connectors">
          <svg viewBox="0 0 600 14" preserveAspectRatio="none">
            {% if concept_map.nodes|length == 4 %}
              <path d="M300 0 L75 14 M300 0 L225 14 M300 0 L375 14 M300 0 L525 14" fill="none" stroke="#004d7c" stroke-width="0.6" stroke-dasharray="2 2"/>
            {% else %}
              <path d="M300 0 L100 14 M300 0 L300 14 M300 0 L500 14" fill="none" stroke="#004d7c" stroke-width="0.6" stroke-dasharray="2 2"/>
            {% endif %}
          </svg>
        </div>
        <div class="cmap__nodes{% if concept_map.nodes|length == 4 %} cmap__nodes--n4{% endif %}">
          {% for node in concept_map.nodes %}
          <div class="cmap__node">
            <div class="cmap__node-head">
              <div class="cmap__node-num">{{ node.num }}</div>
              <div class="cmap__node-lbl">{{ node.label }}</div>
            </div>
            {% if node.descriptor %}<div class="cmap__node-prompt"><em>{{ node.descriptor }}</em></div>{% endif %}
            {% if node.prompt %}<div class="cmap__node-prompt">{{ node.prompt }}</div>{% endif %}
            <div class="cmap__node-slot"></div>
            {% if node.why_prompt %}
              <div class="cmap__node-why">{{ node.why_prompt }}</div>
              <div class="cmap__node-why-slot"></div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>

    {% elif format_id == "decision_tree" and decision_tree.steps %}
      <div class="tree">
        {% if decision_tree.role_label %}
        <div class="tree__role">
          <span class="tree__role-lbl">{{ decision_tree.role_label }}</span>
          <span class="fill fill--md"></span>
          {% if decision_tree.role_descriptor %}<span style="font-size:9.5pt; color:var(--ink-mute)">({{ decision_tree.role_descriptor }})</span>{% endif %}
        </div>
        {% endif %}
        {% if decision_tree.problem %}
        <div class="tree__problem"><strong>Problem:</strong> {{ decision_tree.problem }}</div>
        {% endif %}
        <div class="tree__steps">
          {% for step in decision_tree.steps %}
          <div class="tree__step">
            <div class="tree__step-num"><div class="circle">{{ step.num }}</div>{% if not loop.last %}<div class="stem"></div>{% endif %}</div>
            <div class="tree__step-body">
              <div class="tree__step-prompt">{{ step.prompt }}</div>
              {% if step.branch %}
              <div class="tree__branch">
                <div class="tree__branch-col">
                  <div class="tree__branch-head">{{ step.branch.left_label }}</div>
                  <div class="tree__step-slot tree__step-slot--n3"></div>
                </div>
                <div class="tree__branch-col">
                  <div class="tree__branch-head">{{ step.branch.right_label }}</div>
                  <div class="tree__step-slot tree__step-slot--n3"></div>
                </div>
              </div>
              {% else %}
              <div class="tree__step-slot tree__step-slot--n{{ step.slot_lines }}"></div>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

    {% elif format_id == "ranked" and (ranked.items_list or ranked.ranks) %}
      {% if ranked.stem %}<p class="stem">{{ ranked.stem }}</p>{% endif %}
      <div class="rank">
        {% if ranked.mode == "prefilled_ranks" %}
          {% for r in ranked.ranks %}
          <div class="rank__row">
            <div class="rank__num">{{ r.num }}</div>
            <div class="rank__slot">{% if r.descriptor %}<span style="color:var(--ink-mute); font-size:9pt; font-style:italic">{{ r.descriptor }}</span>{% endif %}</div>
          </div>
          {% endfor %}
        {% else %}
          {% for item in ranked.items_list %}
          <div class="rank__row">
            <div class="rank__num"><span class="rank-blank"></span></div>
            <div class="rank__slot is-prefilled">{{ item }}</div>
          </div>
          {% endfor %}
        {% endif %}
      </div>
      {% if ranked.rule_strip %}
      <div class="rule-strip"><b>{{ ranked.rule_strip_label or 'Rules' }}</b> {{ ranked.rule_strip }}</div>
      {% endif %}
      {% if ranked.follows %}
      <p class="callout">{{ ranked.callout }}</p>
      <div class="rank__follow">
        {% for follow in ranked.follows %}
        <div class="rank__follow-row">
          <div class="rank__follow-lbl">{{ follow.label }}</div>
          <div class="rank__follow-slot"></div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    {% elif format_id == "mini_case" and mini_case.questions %}
      {% if mini_case.scenario %}<p class="scenario">{{ mini_case.scenario | safe }}</p>{% endif %}
      <div class="case__questions">
        {% for q in mini_case.questions %}
        <div class="case__q">
          <div class="case__q-num">{{ q.num }}</div>
          <div class="case__q-body">
            <div class="case__q-prompt">{{ q.prompt }}</div>
            {% if q.step_pair %}
            <div class="case__step-pair">
              {% for sub in q.step_pair %}
              <div>
                <div class="case__step-lbl">{{ sub.label }}</div>
                <div class="case__q-slot case__q-slot--n{{ sub.slot_lines }}"></div>
              </div>
              {% endfor %}
            </div>
            {% else %}
            <div class="case__q-slot case__q-slot--n{{ q.slot_lines }}"></div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>

    {% elif format_id == "tradeoff" and tradeoff.a_label and tradeoff.b_label %}
      {% if tradeoff.scenario %}<p class="scenario">{{ tradeoff.scenario | safe }}</p>{% endif %}
      <div class="tradeoff">
        <div class="tradeoff__col">
          <div class="tradeoff__head tradeoff__option-head"><span class="badge">A</span>{{ tradeoff.a_label }}</div>
          {% if tradeoff.a_pros %}<p class="tradeoff__pros"><b>Pros:</b> {{ tradeoff.a_pros }}</p>{% endif %}
          <div class="tradeoff__row">
            <div class="tradeoff__cell-lbl">Pros of picking A</div>
            <div class="tradeoff__cell"></div>
          </div>
        </div>
        <div class="tradeoff__col">
          <div class="tradeoff__head tradeoff__option-head"><span class="badge">B</span>{{ tradeoff.b_label }}</div>
          {% if tradeoff.b_pros %}<p class="tradeoff__pros"><b>Pros:</b> {{ tradeoff.b_pros }}</p>{% endif %}
          <div class="tradeoff__row">
            <div class="tradeoff__cell-lbl">Pros of picking B</div>
            <div class="tradeoff__cell"></div>
          </div>
        </div>
      </div>
      <div class="tradeoff__choice">
        <span class="tradeoff__choice-lbl">My choice</span>
        <div class="tradeoff__choice-bubbles">
          <span class="tradeoff__choice-bubble">A</span>
          <span class="tradeoff__choice-bubble">B</span>
        </div>
      </div>
      {% if tradeoff.quality_list %}
      <div class="tradeoff__qualities">
        <span class="tradeoff__qualities-lbl">Quality list</span>
        {% for q in tradeoff.quality_list %}<span class="q-chip">{{ q }}</span>{% endfor %}
        <span class="q-chip q-chip--blank">&nbsp;</span>
        <span style="color:var(--ink-mute); font-size:9pt">or write your own</span>
      </div>
      {% endif %}
      {% if tradeoff.justify_prompt %}
      <div class="tradeoff__justify">
        <div class="tradeoff__justify-prompt"><strong>{{ tradeoff.justify_prompt }}</strong></div>
        <div class="tradeoff__justify-slot"></div>
      </div>
      {% endif %}

    {% elif format_id == "three_two_one" and three_two_one.cols %}
      {% if three_two_one.stem %}<p class="stem">{{ three_two_one.stem | safe }}</p>{% endif %}
      <div class="tto">
        {% for col in three_two_one.cols %}
        <div class="tto__col">
          <div class="tto__head">
            <div class="tto__num">{{ col.num }}</div>
            <div class="tto__lbl">{{ col.label }}</div>
          </div>
          <div class="tto__slots">
            {% for i in range(col.slots) %}
            <div class="tto__slot"><div class="tto__slot-num">{{ i + 1 }}</div><div class="tto__slot-line tto__slot-line--n3"></div></div>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>

    {% else %}
      {# Fallback: preserved markdown rendered to HTML. #}
      <div class="eb__fallback">
        {{ fallback_html | safe }}
      </div>
    {% endif %}
  </div>

  <footer class="ef">
    <div class="ef__row1">
      <div class="ef__rubric">
        <div class="ef__rubric-lbl">Teacher · Mastery</div>
        <div class="ef__rubric-row">
          <div class="ef__rubric-cell"><span class="box"></span>Beginning <span class="num">1</span></div>
          <div class="ef__rubric-cell"><span class="box"></span>Developing <span class="num">2</span></div>
          <div class="ef__rubric-cell"><span class="box"></span>Proficient <span class="num">3</span></div>
          <div class="ef__rubric-cell"><span class="box"></span>Mastery <span class="num">4</span></div>
        </div>
      </div>
    </div>
    <div class="ef__row2">
      <div class="ef__comment">
        <div class="ef__comment-lbl">Teacher comment</div>
        <div class="ef__comment-line"></div>
      </div>
      <div class="ef__page-id">{{ page_id }} · {{ format_code }}</div>
    </div>
  </footer>
</section>

</body>
</html>
